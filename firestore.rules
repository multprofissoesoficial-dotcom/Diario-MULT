rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'master') ||
        request.auth.token.email == "faustodv@gmail.com" ||
        request.auth.token.email == "multprofissoesoficial@gmail.com"
      );
    }

    function isCoordenador(franquiaId) {
      return isAuthenticated() && getUserData().role == 'coordenador' && getUserData().franquiaId == franquiaId;
    }

    function isProfessor(franquiaId) {
      return isAuthenticated() && getUserData().role == 'professor' && getUserData().franquiaId == franquiaId;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Franquias
    match /franquias/{franquiaId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Usuários
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        isMaster() || 
        isOwner(userId) || 
        (getUserData().role == 'coordenador' && getUserData().franquiaId == resource.data.franquiaId) ||
        (getUserData().role == 'professor' && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow create: if isMaster() || (isAuthenticated() && getUserData().role == 'coordenador' && request.resource.data.franquiaId == getUserData().franquiaId);
      allow update: if isMaster() || 
                    (isAuthenticated() && getUserData().role == 'coordenador' && resource.data.franquiaId == getUserData().franquiaId) ||
                    (isAuthenticated() && getUserData().role == 'professor' && resource.data.franquiaId == getUserData().franquiaId) ||
                    isOwner(userId);
      allow delete: if isMaster();
    }

    // Missões (Diários)
    match /missions/{missionId} {
      allow read: if isAuthenticated() && (
        isMaster() || 
        resource.data.studentId == request.auth.uid ||
        (getUserData().franquiaId == resource.data.franquiaId && (getUserData().role == 'coordenador' || getUserData().role == 'professor'))
      );
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update: if isMaster() || (isAuthenticated() && getUserData().franquiaId == resource.data.franquiaId && (getUserData().role == 'coordenador' || getUserData().role == 'professor'));
      allow delete: if isMaster();
    }
  }
}
