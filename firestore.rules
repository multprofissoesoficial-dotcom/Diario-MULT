rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. FUNÇÕES DE SEGURANÇA ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // SuperAdmin: Poder total
    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "faustodv@gmail.com" || 
         request.auth.token.email == "multprofissoesoficial@gmail.com");
    }

    // Helper para buscar dados do usuário logado
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    // Verifica se o usuário é Master
    function isMaster() {
      return isSuperAdmin() || (getUserData() != null && getUserData().role == 'master');
    }

    // Verifica se o usuário é da equipe (Master, Coordenador ou Professor)
    function isStaff() {
      return isMaster() || (getUserData() != null && getUserData().role in ['coordenador', 'professor']);
    }

    // Lógica de Identidade do Aluno baseada no E-mail
    function isEmailCompositeId(docId) {
      let emailParts = request.auth.token.email.split('@');
      let prefix = emailParts.size() > 0 ? emailParts[0] : "";
      return docId == prefix;
    }

    function isStudentOwner(studentId) {
      return isAuthenticated() && (
        request.auth.uid == studentId || 
        isEmailCompositeId(studentId) ||
        (resource != null && resource.data.studentId == studentId)
      );
    }

    // --- 2. REGRAS POR COLEÇÃO ---

    // Acesso Global para SuperAdmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Usuários
    match /users/{userId} {
      allow get: if isAuthenticated() && (
        request.auth.uid == userId || 
        isEmailCompositeId(userId) || 
        isStaff() ||
        (resource != null && (resource.data.uid == request.auth.uid || resource.data.email == request.auth.token.email))
      );
      
      allow list: if isAuthenticated() && (
        isStaff() || 
        request.query.limit <= 5
      );

      allow create: if isAuthenticated() && (isMaster() || isSuperAdmin());
      
      allow update: if isAuthenticated() && (
        isMaster() || 
        request.auth.uid == userId ||
        isEmailCompositeId(userId) ||
        (resource != null && resource.data.uid == request.auth.uid)
      );
      
      allow delete: if isMaster();
    }

    // Missões (Diários de Bordo)
    match /missions/{missionId} {
      allow read: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId) ||
        (isStaff() && getUserData() != null && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow create: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(request.resource.data.studentId)
      );
      allow update: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId) ||
        (isStaff() && getUserData() != null && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow delete: if isMaster();
    }

    // Candidaturas (Applications)
    match /applications/{appId} {
      allow read: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId) ||
        (getUserData() != null && getUserData().role == 'rh' && getUserData().franquiaId == resource.data.franquiaId) ||
        (isStaff() && getUserData() != null && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow create: if isAuthenticated() && isStudentOwner(request.resource.data.studentId);
      allow update: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId) ||
        (getUserData() != null && getUserData().role == 'rh' && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow delete: if isMaster();
    }

    // Vagas e Empresas
    match /job_postings/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isMaster() || (getUserData() != null && getUserData().role == 'rh');
    }
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isMaster() || (getUserData() != null && getUserData().role == 'rh');
    }

    // Franquias e Cursos
    match /franquias/{franquiaId} {
      allow read: if true; // Permite leitura pública para que o login liste as unidades
      allow write: if isMaster();
    }
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Matrículas
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }
  }
}