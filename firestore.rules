rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPCM() {
      return isAuthenticated() && getUserData().role in ['master', 'coordenador', 'professor', 'rh'];
    }

    function isATSAdmin() {
      return isAuthenticated() && getUserData().role in ['master', 'coordenador', 'rh'];
    }

    function isOwner(userId) {
      return isAuthenticated() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(userId)).data.legacyUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(userId)).data.uid == request.auth.uid
      );
    }

    function isStudentOwner(studentId) {
      return isAuthenticated() && (
        request.auth.uid == studentId ||
        get(/databases/$(database)/documents/users/$(studentId)).data.legacyUid == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(studentId)).data.uid == request.auth.uid
      );
    }

    function isMaster() {
      return isAuthenticated() && (
        request.auth.token.email == "multprofissoesoficial@gmail.com" ||
        getUserData().role == 'master'
      );
    }

    function isRecent(tsString) {
      return tsString is string && duration.abs(request.time - timestamp(tsString)) < duration.value(5, 'm');
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'xp', 'unlockedBadges', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['master', 'coordenador', 'professor', 'aluno', 'rh'] &&
             data.xp is number &&
             data.unlockedBadges is list && data.unlockedBadges.size() < 100 &&
             data.createdAt is string && (request.method != 'create' || isRecent(data.createdAt));
    }

    function isValidMission(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'franquiaId', 'module', 'classNum', 'content', 'status', 'createdAt']) &&
             data.studentId is string && data.studentId.size() < 128 &&
             data.studentName is string && data.studentName.size() < 100 &&
             data.franquiaId is string && data.franquiaId.size() < 128 &&
             data.module is string && data.module.size() < 100 &&
             data.classNum is number &&
             data.content is string && data.content.size() < 5000 &&
             data.status in ['pending', 'approved', 'bonus'] &&
             data.createdAt is string && (request.method != 'create' || isRecent(data.createdAt));
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['courseId', 'courseName', 'currentLesson', 'status', 'createdAt']) &&
             data.courseId is string && data.courseId.size() < 128 &&
             data.courseName is string && data.courseName.size() < 100 &&
             data.currentLesson is number &&
             data.status in ['active', 'completed', 'dropped'] &&
             data.createdAt is string;
    }

    // Franquias
    match /franquias/{franquiaId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Usuários
    match /users/{userId} {
      // Students can only GET their own document.
      // We check if the doc ID is their UID OR if the legacyUid field matches their UID.
      allow get: if isAuthenticated() && (
        request.auth.uid == userId || 
        (resource != null && request.auth.uid == resource.data.legacyUid) ||
        (resource != null && request.auth.uid == resource.data.uid)
      );
      
      // Allow students to query (list) their own document via uid or legacyUid
      allow list: if isAuthenticated() && (
        isPCM() || 
        (resource.data.uid == request.auth.uid || resource.data.legacyUid == request.auth.uid)
      );

      // PCM can read any user in their franchise (or all if master/rh)
      allow get: if isPCM() && (
        getUserData().role in ['master', 'rh'] || 
        getUserData().franquiaId == resource.data.franquiaId
      );

      // Write and Delete: ONLY Master (as requested for security lockdown)
      allow write, delete: if isMaster();

      // Enrollments sub-collection
      match /enrollments/{enrollmentId} {
        allow read: if isOwner(userId) || isPCM();
        allow create: if isPCM() && isValidEnrollment(request.resource.data);
        allow update: if (isOwner(userId) || isPCM()) && isValidEnrollment(request.resource.data);
        allow delete: if isMaster();
      }
    }

    // Vagas (Job Postings)
    match /job_postings/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isATSAdmin();
    }

    // Empresas (Companies)
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isATSAdmin();
    }

    // Candidaturas (Applications)
    match /applications/{applicationId} {
      allow read: if isATSAdmin() || (isAuthenticated() && isStudentOwner(resource.data.studentId));
      allow create: if isAuthenticated() && isStudentOwner(request.resource.data.studentId);
      allow update, delete: if isATSAdmin();
    }

    // Missões (Diários)
    match /missions/{missionId} {
      allow read: if isAuthenticated() && (
        isPCM() || 
        isStudentOwner(resource.data.studentId)
      );
      
      allow create: if (
        (isPCM() && request.resource.data.franquiaId == getUserData().franquiaId) || 
        (isAuthenticated() && isStudentOwner(request.resource.data.studentId))
      ) && isValidMission(request.resource.data);

      allow update: if (
        (isPCM() && resource.data.franquiaId == getUserData().franquiaId) || 
        (isAuthenticated() && isStudentOwner(resource.data.studentId) && request.resource.data.status == resource.data.status)
      ) && isValidMission(request.resource.data);

      allow delete: if isMaster();
    }
  }
}
