rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isPCM() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role in ['master', 'coordenador', 'professor', 'rh'];
    }

    function isATSAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role in ['master', 'coordenador', 'rh'];
    }

    function isOwner(userId) {
      let userPath = /databases/$(database)/documents/users/$(userId);
      return isAuthenticated() && (
        request.auth.uid == userId || 
        (exists(userPath) && (get(userPath).data.legacyUid == request.auth.uid || get(userPath).data.uid == request.auth.uid))
      );
    }

    function isStudentOwner(studentId) {
      return isOwner(studentId);
    }

    function isMaster() {
      let data = getUserData();
      return isAuthenticated() && (
        request.auth.token.email == "multprofissoesoficial@gmail.com" ||
        (data != null && data.role == 'master')
      );
    }

    function isRecent(tsString) {
      return tsString is string && duration.abs(request.time - timestamp(tsString)) < duration.value(5, 'm');
    }

    // --- SEÇÃO DE USUÁRIOS REFORMULADA ---
    match /users/{userId} {
      
      // GET/LIST: Aluno acessa a si mesmo (ID direto ou Legacy)
      allow get: if isAuthenticated() && (
        request.auth.uid == userId || 
        (resource != null && (resource.data.legacyUid == request.auth.uid || resource.data.uid == request.auth.uid))
      );
      
      allow list: if isAuthenticated() && (
        isPCM() || 
        (request.query.limit <= 10 && (resource.data.uid == request.auth.uid || resource.data.legacyUid == request.auth.uid))
      );

      // CREATE/UPDATE: Permite a migração se o UID do aluno for o dono do legacyUid
      // Isso mata o erro de "permission-denied" no loop de migração
      allow create, update: if isAuthenticated() && (
        isMaster() || 
        request.auth.uid == userId ||
        (request.resource.data.legacyUid == request.auth.uid) ||
        (resource != null && resource.data.legacyUid == request.auth.uid)
      );

      // DELETE: Exclusivo para o Master
      allow delete: if isMaster();

      // Enrollments
      match /enrollments/{enrollmentId} {
        allow read: if isOwner(userId) || isPCM();
        allow create: if isPCM();
        allow update: if isOwner(userId) || isPCM();
        allow delete: if isMaster();
      }
    }

    // Vagas (Job Postings)
    match /job_postings/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isATSAdmin();
    }

    // Empresas (Companies)
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isATSAdmin();
    }

    // Candidaturas (Applications)
    match /applications/{applicationId} {
      allow read: if isATSAdmin() || (isAuthenticated() && isStudentOwner(resource.data.studentId));
      allow create: if isAuthenticated() && isStudentOwner(request.resource.data.studentId);
      allow update, delete: if isATSAdmin();
    }

    // Missões (Diários)
    match /missions/{missionId} {
      allow read: if isAuthenticated() && (isPCM() || isStudentOwner(resource.data.studentId));
      allow create: if isAuthenticated() && isStudentOwner(request.resource.data.studentId);
      allow update: if isAuthenticated() && (isPCM() || isStudentOwner(resource.data.studentId));
      allow delete: if isMaster();
    }
  }
}