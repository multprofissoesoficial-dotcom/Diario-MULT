rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. FUNÇÕES DE SEGURANÇA ---
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // SuperAdmin: Poder total (E-mail verificado obrigatório)
    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "faustodv@gmail.com" || 
         request.auth.token.email == "multprofissoesoficial@gmail.com") &&
        request.auth.token.email_verified == true;
    }

    // Helper para buscar dados do usuário logado
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }

    // Verifica se o usuário é Master
    function isMaster() {
      return isSuperAdmin() || (getUserData() != null && getUserData().role == 'master');
    }

    // Verifica se o usuário é da equipe (Master, Coordenador ou Professor)
    function isStaff() {
      return isMaster() || (getUserData() != null && getUserData().role in ['coordenador', 'professor']);
    }

    // Lógica Híbrida de Identidade do Aluno
    function isEmailCompositeId(docId) {
      let emailParts = request.auth.token.email.split('@');
      let prefix = emailParts.size() > 0 ? emailParts[0] : "";
      let domainParts = emailParts.size() > 1 ? emailParts[1].split('.') : [];
      let domain = domainParts.size() > 0 ? domainParts[0] : "";
      return docId == domain + "_" + prefix;
    }

    function isStudentOwner(studentId, docFranquiaId) {
      return (getUserData() != null && (
        request.auth.uid == studentId || 
        (
          studentId.split('_').size() >= 2 && 
          studentId.split('_')[1] == request.auth.token.email.split('@')[0] && 
          studentId.split('_')[0] == getUserData().franquiaId &&
          (docFranquiaId == null || docFranquiaId == getUserData().franquiaId)
        )
      )) || isEmailCompositeId(studentId);
    }

    // --- 2. REGRAS POR COLEÇÃO ---

    // Acesso Global para SuperAdmin
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Usuários
    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isEmailCompositeId(userId) || isStaff());
      allow list: if isStaff();
      allow create, update: if isAuthenticated() && (
        isMaster() || 
        request.auth.uid == userId ||
        isEmailCompositeId(userId) ||
        (getUserData() != null && getUserData().role == 'coordenador' && getUserData().franquiaId == request.resource.data.franquiaId)
      );
      allow delete: if isMaster();
    }

    // Missões (Diários de Bordo)
    match /missions/{missionId} {
      allow read: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId, resource.data.franquiaId) ||
        (isStaff() && getUserData() != null && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow create: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(request.resource.data.studentId, request.resource.data.franquiaId)
      );
      allow update: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId, resource.data.franquiaId) ||
        (isStaff() && getUserData() != null && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow delete: if isMaster();
    }

    // Candidaturas (Applications)
    match /applications/{appId} {
      allow read: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId, null) ||
        (getUserData() != null && getUserData().role == 'rh' && getUserData().franquiaId == resource.data.franquiaId) ||
        (isStaff() && getUserData() != null && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow create: if isAuthenticated() && isStudentOwner(request.resource.data.studentId, null);
      allow update: if isAuthenticated() && (
        isMaster() || 
        isStudentOwner(resource.data.studentId, null) ||
        (getUserData() != null && getUserData().role == 'rh' && getUserData().franquiaId == resource.data.franquiaId)
      );
      allow delete: if isMaster();
    }

    // Vagas e Empresas
    match /job_postings/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isMaster() || (getUserData() != null && getUserData().role == 'rh');
    }
    match /companies/{companyId} {
      allow read: if isAuthenticated();
      allow write: if isMaster() || (getUserData() != null && getUserData().role == 'rh');
    }

    // Franquias e Cursos
    match /franquias/{franquiaId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Matrículas
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }
  }
}