rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isPCM() {
      return isAuthenticated() && getUserData().role in ['master', 'coordenador', 'professor', 'rh'];
    }

    function isATSAdmin() {
      return isAuthenticated() && getUserData().role in ['master', 'coordenador', 'rh'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isMaster() {
      return isAuthenticated() && (
        request.auth.token.email == "multprofissoesoficial@gmail.com" ||
        getUserData().role == 'master'
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'xp', 'unlockedBadges', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['master', 'coordenador', 'professor', 'aluno', 'rh'] &&
             data.xp is number &&
             data.unlockedBadges is list && data.unlockedBadges.size() < 100 &&
             data.createdAt is string;
    }

    function isValidMission(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'franquiaId', 'module', 'classNum', 'content', 'status', 'createdAt']) &&
             data.studentId is string && data.studentId.size() < 128 &&
             data.studentName is string && data.studentName.size() < 100 &&
             data.franquiaId is string && data.franquiaId.size() < 128 &&
             data.module is string && data.module.size() < 100 &&
             data.classNum is number &&
             data.content is string && data.content.size() < 5000 &&
             data.status in ['pending', 'approved', 'bonus'] &&
             data.createdAt is string;
    }

    // Franquias
    match /franquias/{franquiaId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Usuários
    match /users/{userId} {
      // Students can only GET their own document. They CANNOT LIST.
      allow get: if isOwner(userId);
      
      // PCM can list and read any user in their franchise (or all if master/rh)
      allow list: if isPCM();
      allow get: if isPCM() && (
        getUserData().role in ['master', 'rh'] || 
        getUserData().franquiaId == resource.data.franquiaId
      );

      // Create: Only master, coordinator (within franchise), or RH
      allow create: if (isATSAdmin() || (
        isAuthenticated() && getUserData().role == 'coordenador' && 
        request.resource.data.franquiaId == getUserData().franquiaId &&
        request.resource.data.role in ['professor', 'aluno']
      )) && isValidUser(request.resource.data);

      // Update: Owner (limited fields), Master, RH, or PCM (within franchise)
      allow update: if (
        (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.franquiaId == resource.data.franquiaId) || 
        isATSAdmin() || 
        (isPCM() && resource.data.franquiaId == getUserData().franquiaId && (request.resource.data.role == resource.data.role || isATSAdmin()))
      ) && isValidUser(request.resource.data);

      allow delete: if isMaster();
    }

    // Vagas (Job Postings)
    match /job_postings/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isATSAdmin();
    }

    // Candidaturas (Applications)
    match /applications/{applicationId} {
      allow read: if isATSAdmin() || (isAuthenticated() && resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if isATSAdmin();
    }

    // Missões (Diários)
    match /missions/{missionId} {
      allow read: if isAuthenticated() && (
        isPCM() || 
        resource.data.studentId == request.auth.uid
      );
      
      allow create: if (
        (isPCM() && request.resource.data.franquiaId == getUserData().franquiaId) || 
        (isAuthenticated() && request.resource.data.studentId == request.auth.uid)
      ) && isValidMission(request.resource.data);

      allow update: if (
        (isPCM() && resource.data.franquiaId == getUserData().franquiaId) || 
        (isAuthenticated() && resource.data.studentId == request.auth.uid && request.resource.data.status == resource.data.status)
      ) && isValidMission(request.resource.data);

      allow delete: if isMaster();
    }
  }
}
