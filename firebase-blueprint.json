{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including role and franchise association.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["master", "coordenador", "professor", "aluno", "rh"] },
        "franquiaId": { "type": "string" },
        "turma": { "type": "string" },
        "xp": { "type": "integer" },
        "unlockedBadges": { "type": "array", "items": { "type": "string" } },
        "resumeUrl": { "type": "string", "format": "uri" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "phone": { "type": "string" },
        "atsTermsAccepted": { "type": "boolean" },
        "atsTermsAcceptedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "JobPosting": {
      "title": "JobPosting",
      "description": "Job posting for the ATS module.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "companyId": { "type": "string" },
        "companyName": { "type": "string" },
        "description": { "type": "string" },
        "requiredSkills": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["aberta", "fechada"] },
        "franquiaId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdByUid": { "type": "string" }
      },
      "required": ["title", "companyId", "requiredSkills", "status", "franquiaId"]
    },
    "Application": {
      "title": "Application",
      "description": "Job application from a student.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "jobId": { "type": "string" },
        "studentId": { "type": "string" },
        "matchScore": { "type": "integer" },
        "status": { "type": "string", "enum": ["pendente", "encaminhado", "contratado", "rejeitado"] },
        "hrNotes": { "type": "string" },
        "hrRating": { "type": "integer", "minimum": 1, "maximum": 5 },
        "statusHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "date": { "type": "string", "format": "date-time" },
              "updatedByRole": { "type": "string" }
            }
          }
        },
        "appliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["jobId", "studentId", "matchScore", "status", "appliedAt"]
    },
    "Company": {
      "title": "Company",
      "description": "Partner company for job postings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "franquiaId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "contactPerson", "phone", "createdAt", "franquiaId"]
    },
    "Franquia": {
      "title": "Franquia",
      "description": "Franchise unit data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "cidade": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome"]
    },
    "Mission": {
      "title": "Mission",
      "description": "Student daily journey record (mission).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "franquiaId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "xp": { "type": "integer" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "feedback": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "approvedAt": { "type": "string", "format": "date-time" },
        "approvedBy": { "type": "string" }
      },
      "required": ["studentId", "title", "status"]
    }
  },
  "firestore": {
    "/franquias/{franquiaId}": {
      "schema": "Franquia",
      "description": "Collection of franchise units."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/missions/{missionId}": {
      "schema": "Mission",
      "description": "Collection of student missions."
    },
    "/job_postings/{jobId}": {
      "schema": "JobPosting",
      "description": "Collection of job postings for ATS."
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Collection of job applications."
    },
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Collection of partner companies."
    }
  }
}
